{
  "name": "quiz-platform",
  "version": "1.0.0",
  "description": "Interactive Quiz Platform",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "npm --prefix server install",
    "build:css": "npx tailwindcss -i client/css/tailwind-input.css -o client/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i client/css/tailwind-input.css -o client/css/tailwind.css --watch",
    "build": "npm run build:css",
    "start": "node server/index.js",
    "dev": "npm --prefix server run dev",
    "test": "npm --prefix server test"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "esbuild": "^0.27.3",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@studio-freight/lenis": "^1.0.42"
  }
}
