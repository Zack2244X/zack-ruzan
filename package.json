{
  "name": "quiz-platform",
  "version": "1.0.0",
  "description": "Interactive Quiz Platform",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "cd server && npm install",
    "build:css": "npx tailwindcss -i client/css/tailwind-input.css -o client/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i client/css/tailwind-input.css -o client/css/tailwind.css --watch",
    "build": "npm run build:css",
    "start": "cd server && node index.js",
    "dev": "cd server && npm run dev",
    "test": "cd server && npm test"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
